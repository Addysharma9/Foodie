{
  "expo": {
    "name": "Foodie",
    "slug": "Foodie",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arunsharma9018.Foodie",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "google",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.88618355277-tqbeqvv88c7f4cm37g1d4urblpmonvio"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.arunsharma9018.Foodie"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.88618355277-tqbeqvv88c7f4cm37g1d4urblpmonvio"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
